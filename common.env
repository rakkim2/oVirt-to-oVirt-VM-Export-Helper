# Shared helpers for v2v shell scripts.
# Keep this file side-effect free (no option changes, no exits).

now_ts() {
  date '+%F %T'
}

log() {
  echo "[$(now_ts)] $*"
}

is_enabled() {
  local v
  v="$(printf '%s' "${1-}" | tr '[:upper:]' '[:lower:]')"
  case "$v" in
    1|true|yes|y) return 0 ;;
    *) return 1 ;;
  esac
}

normalize_bool() {
  local v
  v="$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')"
  case "$v" in
    1|true|yes|y) echo "true" ;;
    0|false|no|n) echo "false" ;;
    *)
      echo "error: boolean value must be true/false (or 1/0): $1" >&2
      return 1
      ;;
  esac
}

v2v_preserve_env() {
  local key=""
  local set_name=""
  local val_name=""

  for key in "$@"; do
    set_name="__V2V_ENV_SET_${key}__"
    val_name="__V2V_ENV_VAL_${key}__"
    # Preserve only non-empty env values as explicit overrides.
    # Empty exports should not erase values from v2v.conf.
    if [[ "${!key+x}" == "x" && -n "${!key}" ]]; then
      printf -v "$set_name" '%s' "1"
      printf -v "$val_name" '%s' "${!key}"
    else
      printf -v "$set_name" '%s' "0"
      unset "$val_name" >/dev/null 2>&1 || true
    fi
  done
}

v2v_restore_env() {
  local key=""
  local set_name=""
  local val_name=""
  local set_val=""
  local val=""

  for key in "$@"; do
    set_name="__V2V_ENV_SET_${key}__"
    set_val="${!set_name-0}"
    if [[ "$set_val" != "1" ]]; then
      continue
    fi
    val_name="__V2V_ENV_VAL_${key}__"
    val="${!val_name-}"
    printf -v "$key" '%s' "$val"
  done
}

v2v_preserved_var_is_set() {
  local key="$1"
  local set_name="__V2V_ENV_SET_${key}__"
  [[ "${!set_name-0}" == "1" ]]
}

v2v_load_config_with_env() {
  local config_file="$1"
  shift
  local conf_source="default-env"
  local -a keep_vars=("$@")

  if (( ${#keep_vars[@]} > 0 )); then
    v2v_preserve_env "${keep_vars[@]}"
  fi
  if [[ -f "$config_file" ]]; then
    # shellcheck source=/dev/null
    source "$config_file"
    conf_source="$config_file"
  fi
  if (( ${#keep_vars[@]} > 0 )); then
    v2v_restore_env "${keep_vars[@]}"
  fi
  printf '%s' "$conf_source"
}

# Read a simple KEY=value from config text as a fallback.
# - Uses the last matching assignment line.
# - Supports optional single/double quotes and strips trailing CR.
v2v_read_conf_value() {
  local config_file="$1"
  local key="$2"
  local line=""

  [[ -f "$config_file" ]] || return 1

  line="$(
    awk -v k="$key" '
      {
        s = $0
        if (s ~ "^[[:space:]]*" k "[[:space:]]*=") {
          sub("^[[:space:]]*" k "[[:space:]]*=[[:space:]]*", "", s)
          print s
          next
        }
        if (s ~ "^[[:space:]]*(export|declare|typeset|local)([[:space:]-][^=]*)*[[:space:]]+" k "[[:space:]]*=") {
          sub("^[[:space:]]*(export|declare|typeset|local)([[:space:]-][^=]*)*[[:space:]]+" k "[[:space:]]*=[[:space:]]*", "", s)
          print s
        }
      }
    ' "$config_file" | tail -n1
  )"

  [[ -n "$line" ]] || return 1

  line="${line%%#*}"
  line="${line%$'\r'}"
  line="$(printf '%s' "$line" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"

  if [[ "$line" == \"*\" && "$line" == *\" ]]; then
    line="${line#\"}"
    line="${line%\"}"
  elif [[ "$line" == \'*\' && "$line" == *\' ]]; then
    line="${line#\'}"
    line="${line%\'}"
  fi

  printf '%s' "$line"
}

# Expand common config placeholders in a value string.
# Supported tokens:
#   ${SCRIPT_BASE_DIR}, $SCRIPT_BASE_DIR
#   ${DATA_BASE_DIR},   $DATA_BASE_DIR
v2v_expand_conf_placeholders() {
  local value="${1-}"
  local out="$value"
  local script_base="${SCRIPT_BASE_DIR:-}"
  local data_base="${DATA_BASE_DIR:-}"

  if [[ -n "$script_base" ]]; then
    out="${out//'${SCRIPT_BASE_DIR}'/$script_base}"
    out="${out//'$SCRIPT_BASE_DIR'/$script_base}"
  fi
  if [[ -n "$data_base" ]]; then
    out="${out//'${DATA_BASE_DIR}'/$data_base}"
    out="${out//'$DATA_BASE_DIR'/$data_base}"
  fi

  printf '%s' "$out"
}
